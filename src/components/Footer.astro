---
import { getAssetBase } from '../lib/assetBase';

const base = getAssetBase(Astro.url.pathname);
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-column">
        <h3>Archura Media</h3>
        <p>
          Archura Media is a digital marketing agency focused on helping businesses grow with clarity and control.
        </p>
      </div>
      <div class="footer-column">
        <h3>Services</h3>
        <ul class="footer-links">
          <li><a href={`${base}services/SearchEngineOptimization`}>Search Engine Optimization</a></li>
          <li><a href={`${base}services/ContentMarketing`}>Content Marketing</a></li>
          <li><a href={`${base}services/PPCAdvertising`}>PPC Advertising</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h3>Industries</h3>
        <ul class="footer-links">
          <li><a href={`${base}industry/iGaming`}>iGaming</a></li>
          <li><a href={`${base}industry/Crypto`}>Crypto</a></li>
          <li><a href={`${base}industry/AI`}>AI</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h3>Blog</h3>
        <ul class="footer-links">
          <li><a href={`${base}blog/`}>All Posts</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2025 Archura Media. All rights reserved.</p>
    </div>
  </div>
</footer>
