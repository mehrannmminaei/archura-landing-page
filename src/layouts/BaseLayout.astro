---
import { getAssetBase } from '../lib/assetBase';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  robots?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  extraCss?: string[];
}

const {
  title,
  description = 'Archura Media digital marketing insights and blog.',
  canonical,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = 'website',
  robots = 'index, follow',
  jsonLd,
  extraCss = [],
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://www.archuramedia.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const basePath = getAssetBase(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" href={`${basePath}favicon.ico`} type="image/x-icon" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@5.15.4/css/all.min.css" />
    <link rel="stylesheet" href={`${basePath}styles/nav-v6.css`} />
    <link rel="stylesheet" href={`${basePath}styles/header-v2.css`} />
    <link rel="stylesheet" href={`${basePath}styles/footer-v1.css`} />
    <link rel="stylesheet" href={`${basePath}styles/layout-v6.css`} />
    <link rel="stylesheet" href={`${basePath}styles/newNav-v4.css`} />
    <link rel="stylesheet" href={`${basePath}styles/blog.css`} />
    {extraCss.map((css) => <link rel="stylesheet" href={`${basePath}${css}`} />)}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
    <script src={`${basePath}script/newNavToggles.js`} defer></script>
    <script src={`${basePath}script/layout.js`} defer></script>
    <script src={`${basePath}script/mobileMenu-v3.js`} defer></script>
  </head>
  <body class="blog-layout">
    <slot />
  </body>
</html>
