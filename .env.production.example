# Production Docker — copy to .env and fill in values
# cp .env.production.example .env

# Public URL of the site (no trailing slash)
SITE_URL=https://www.archuramedia.com
PUBLIC_URL=https://www.archuramedia.com

# HTTP port exposed on the host (use 80 or 443 if behind a reverse proxy)
HTTP_PORT=80

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=archura_blog

# CMS API secrets — generate random strings for production
JWT_SECRET=change-me-jwt-secret
WEBHOOK_SECRET=change-me-webhook-secret

# Allowed browser origins for the admin panel (usually same as PUBLIC_URL)
CORS_ORIGIN=https://www.archuramedia.com

# Seed demo content on first API start (true/false)
SEED_ON_START=true

# Shared secret: API → web rebuild server (auto publish rebuild)
# Must match between api and web containers (set in docker-compose.prod.yml)
